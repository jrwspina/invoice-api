# Postgres credentials consumed by the db/test-db containers
POSTGRES_DB=invoices
POSTGRES_TEST_DB=invoices_test
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# App-facing database URLs host perspective (uvicorn and pytest run on the host).
# Inside compose, worker/beat override these to point at the db service (db:5432).
# Credentials must match POSTGRES_USER / POSTGRES_PASSWORD above.
POSTGRES_URL=postgresql+asyncpg://admin:password@localhost:5432/invoices
TEST_POSTGRES_URL=postgresql+asyncpg://admin:password@localhost:5433/invoices_test

# Generate a real value with: openssl rand -hex 32
SECRET_KEY=changeme

REDIS_URL=redis://localhost:6379/0

# Local email is captured by Mailpit; no real credentials are needed for local dev.
MAIL_SERVER=localhost
MAIL_PORT=1025
EMAIL_FROM=noreply@invoice.local
